# audit-web — environment variables
# Copy to api/.env and fill in real values.
# Never commit api/.env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3500

# ── Database — Turso (libSQL) ─────────────────────────────────────────────────
# Create a free DB at https://turso.tech
DATABASE_URL=libsql://your-db-name.aws-eu-west-1.turso.io
DATABASE_AUTH_TOKEN=your-auth-token-here
