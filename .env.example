# audit-web — environment variables
# Copy to api/.env and fill in real values.
# Never commit api/.env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3500

# ── Database — Turso (libSQL) ─────────────────────────────────────────────────
# Create a free DB at https://turso.tech
DATABASE_URL=libsql://your-db-name.aws-eu-west-1.turso.io
DATABASE_AUTH_TOKEN=your-auth-token-here

# ── Admin auth ────────────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-at-least-32-chars

ADMIN_USERNAME=admin
# Generate hash: node scripts/hash-password.js "your-password"
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# ── Email (SMTP) — leave empty to skip email sending in local dev ─────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=yourpassword
EMAIL_FROM="Devies Audit <audit@devies.se>"

# ── Rate limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_MAX_AUDIT=5
